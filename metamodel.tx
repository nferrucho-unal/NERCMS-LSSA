Model: 
    'system_of_systems' name=ID ':' 
        elements*=ModelElement
; 

ModelElement:
    Subsystem | Connector | Comment
;

Comment:
    /\/\/.*$/
;

// Support for SoS modeling
Subsystem:
    'subsystem' name=ID '{'
        elements*=Element
    '}'
;

Element: 
    Component | Connector | Comment
; 

Component: 
    'component' name=ID ':' tier=TierType type=ComponentType 
    (properties=ComponentProperties)?
; 

// Attributes, easily extensibles
ComponentProperties:
    '{'
        ('tech' '=' tech=STRING)?
        ('port' '=' port=INT)?
    '}'
;

TierType: 
    'presentation' | 'communication' | 'logic' | 'data' | 'physical' | 'edge' | 'external' 
; 

// Generalised but still adapted to critical infrastructure context
ComponentType: 
    'web_ui'          | 
    'mobile_app'      | 
    'api_gateway'     | 
    'microservice'    | 
    'domain_service'  | 
    'event_broker'    | 
    'dashboard'       | 
    'database'        | 
    'data_lake'       | 
    'edge_node'       | 
    'sensor'          | 
    'actuator'        |
    'external_agency'   
; 

Connectable:
    Component | Subsystem
;

// Enriched connectors with protocol information
Connector: 
    'connector' type=ConnectorType from=[Connectable|FQN] '->' to=[Connectable|FQN] 
    (properties=ConnectorProperties)?
; 

FQN:
    ID ('.' ID)*
;

ConnectorType: 
    'data_stream'       | 
    'control_command'   | 
    'event_notification'| 
    'dependency' 
;

ConnectorProperties:
    '{'
        ('style' '=' style=InteractionSyte)?
        ('protocol' '=' protocol=ProtocolType)?
    '}'
; 

ProtocolType:
    'Tcp' | 'WebSockets' | 'Http' | 'gRPC' |'MQTT' | 'AMQP' | 'REST'
;

InteractionSyte:
    'RequestResponse' | 'MessageQueue' | 'Pub/Sub'
;
